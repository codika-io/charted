---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DottedSeparator from '../components/DottedSeparator.astro';
import { getDomainFromId, getDomainLabel } from '../lib/domain';
import type { Domain } from '../lib/domain';

const allTopics = await getCollection('topics');

// ── Identify roots, branches, and sub-topics ──
const roots = allTopics.filter(t => !t.data.parent);
const branches = allTopics.filter(t => t.data.parent && !t.data.parent.includes('/'));
const subTopics = allTopics.filter(t => t.data.parent?.includes('/'));

// ── Aggregate stats ──
const totalCount = allTopics.length;
const populated = allTopics.filter(t => t.data.status !== 'stub').length;
const agentWritten = allTopics.filter(t => t.data.author === 'agent').length;
const humanReviewed = allTopics.filter(t => t.data.status === 'review' || t.data.status === 'complete').length;
const complete = allTopics.filter(t => t.data.status === 'complete').length;

// ── Group by domain ──
type DomainData = {
  domain: Domain;
  label: string;
  root: typeof roots[0] | undefined;
  branches: {
    branch: typeof branches[0];
    branchBase: string;
    topics: typeof subTopics;
    populated: number;
    total: number;
  }[];
  populated: number;
  total: number;
};

const domainOrder: Domain[] = ['mathematics', 'computer-science', 'physics'];

const domains: DomainData[] = domainOrder.map(domain => {
  const domainBranches = branches
    .filter(b => b.data.parent === domain)
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

  const branchData = domainBranches.map(branch => {
    const branchBase = branch.id.replace(/\/index$/, '');
    const topics = subTopics
      .filter(t => t.data.parent === branchBase)
      .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
    const populatedCount = topics.filter(t => t.data.status !== 'stub').length;
    return {
      branch,
      branchBase,
      topics,
      populated: populatedCount,
      total: topics.length,
    };
  });

  const totalTopics = branchData.reduce((sum, b) => sum + b.total, 0);
  const populatedTopics = branchData.reduce((sum, b) => sum + b.populated, 0);

  return {
    domain,
    label: getDomainLabel(domain),
    root: roots.find(r => r.id === domain || r.id === `${domain}/index`),
    branches: branchData,
    populated: populatedTopics,
    total: totalTopics,
  };
}).filter(d => d.branches.length > 0);

// ── Status badge colors ──
const statusColors: Record<string, string> = {
  stub: 'bg-surface-100 text-surface-500',
  draft: 'bg-accent-50 text-accent-600',
  review: 'bg-yellow-50 text-yellow-700',
  complete: 'bg-green-50 text-green-700',
};
---

<BaseLayout title="Status" description="Content status and progress across all Charted topics.">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="text-4xl md:text-5xl mb-6">Status</h1>
    <p class="text-xl text-surface-600 leading-relaxed mb-8">
      Content status across all topics. Every article starts as a stub and moves through the editorial pipeline.
    </p>

    <DottedSeparator />

    {/* ── Summary stats ── */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="border border-surface-200 p-4">
        <div class="font-mono text-2xl">{populated}<span class="text-surface-400">/{totalCount}</span></div>
        <div class="font-mono text-xs uppercase tracking-wider text-surface-500 mt-1">Populated</div>
      </div>
      <div class="border border-surface-200 p-4">
        <div class="font-mono text-2xl">{agentWritten}</div>
        <div class="font-mono text-xs uppercase tracking-wider text-surface-500 mt-1">Agent-written</div>
      </div>
      <div class="border border-surface-200 p-4">
        <div class="font-mono text-2xl">{humanReviewed}</div>
        <div class="font-mono text-xs uppercase tracking-wider text-surface-500 mt-1">Human-reviewed</div>
      </div>
      <div class="border border-surface-200 p-4">
        <div class="font-mono text-2xl">{complete}</div>
        <div class="font-mono text-xs uppercase tracking-wider text-surface-500 mt-1">Complete</div>
      </div>
    </div>

    <DottedSeparator variant="dashed" />

    {/* ── Per-domain sections ── */}
    {domains.map(d => {
      const pct = d.total > 0 ? Math.round((d.populated / d.total) * 100) : 0;
      return (
        <div class="mb-16">
          {/* Domain header + progress bar */}
          <div class="flex items-center gap-4 mb-6">
            <h2 class="text-2xl whitespace-nowrap">{d.label}</h2>
            <div class="flex-1 h-3 bg-surface-100 overflow-hidden">
              <div class="h-full bg-accent-500 transition-all" style={`width: ${pct}%`} />
            </div>
            <span class="font-mono text-sm text-surface-500 whitespace-nowrap">{pct}%</span>
          </div>

          {/* Per-branch tables */}
          {d.branches.map(b => (
            <div class="mb-10">
              <h3 class="text-lg mb-3">
                <a href={`/${b.branch.id}`} class="hover:text-accent-600 transition-colors">
                  {b.branch.data.title}
                </a>
                <span class="text-surface-400 text-sm ml-2">({b.total} topics)</span>
              </h3>

              {b.topics.length > 0 ? (
                <div class="overflow-x-auto">
                  <table class="w-full text-sm border-collapse">
                    <thead>
                      <tr class="border-b border-dashed border-surface-200">
                        <th class="font-mono text-xs uppercase tracking-wider text-surface-500 text-left py-2 pr-4">Topic</th>
                        <th class="font-mono text-xs uppercase tracking-wider text-surface-500 text-left py-2 pr-4">Status</th>
                        <th class="font-mono text-xs uppercase tracking-wider text-surface-500 text-left py-2 pr-4">Author</th>
                        <th class="font-mono text-xs uppercase tracking-wider text-surface-500 text-left py-2 pr-4">Ag. Reviews</th>
                        <th class="font-mono text-xs uppercase tracking-wider text-surface-500 text-left py-2 pr-4">Hum. Review</th>
                        <th class="font-mono text-xs uppercase tracking-wider text-surface-500 text-left py-2">Contributors</th>
                      </tr>
                    </thead>
                    <tbody>
                      {b.topics.map(topic => {
                        const hasHumanReview = topic.data.status === 'review' || topic.data.status === 'complete';
                        const contribs = topic.data.contributors;
                        return (
                          <tr class="border-b border-dotted border-surface-100">
                            <td class="py-2 pr-4">
                              <a href={`/${topic.id}`} class="hover:text-accent-600 transition-colors">
                                {topic.data.title}
                              </a>
                            </td>
                            <td class="py-2 pr-4">
                              <span class={`font-mono text-xs uppercase tracking-wider px-2 py-0.5 ${statusColors[topic.data.status] ?? ''}`}>
                                {topic.data.status}
                              </span>
                            </td>
                            <td class="py-2 pr-4 font-mono text-xs text-surface-500">
                              {topic.data.author ?? '—'}
                            </td>
                            <td class="py-2 pr-4 font-mono text-xs text-surface-500">
                              {topic.data.agentReviewCount}
                            </td>
                            <td class="py-2 pr-4 font-mono text-xs text-surface-500">
                              {hasHumanReview ? '✓' : '—'}
                            </td>
                            <td class="py-2 font-mono text-xs text-surface-500">
                              {contribs && contribs.length > 0 ? contribs.join(', ') : '—'}
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              ) : (
                <p class="text-surface-400 text-sm">No sub-topics yet.</p>
              )}
            </div>
          ))}

          <DottedSeparator variant="dashed" />
        </div>
      );
    })}
  </div>
</BaseLayout>
